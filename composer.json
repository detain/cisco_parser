{
	"name": "detain/cisco_parser",
	"type": "library",
	"description": "Cisco IOS communications and configuration parsing library",
	"keywords": [
		"cisco",
		"cisco-ios",
		"ios",
		"ios-xe",
		"netconf",
		"router",
		"switch",
		"catalyst",
		"network",
		"network-automation",
		"network-configuration",
		"network-device",
		"network-monitoring",
		"network-programmability",
		"configuration-parser",
		"parser",
		"automation"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"email": "detain@interserver.net",
			"homepage": "https:\/\/my.interserver.net\/"
		}
	],
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.0"
	},
	"suggest": {
		"ext-ssh2": "Required for connecting to Cisco IOS devices via the CiscoLoader class"
	},
	"autoload": {
		"psr-4": {
			"Detain\\CiscoParser\\": "src"
		}
	},
	"bin": [
		"bin/cisco_parser.php"
	],
	"scripts": {
		"test": "phpunit tests/ -v",
		"test-coverage": "phpunit tests/ -v --coverage-clover coverage.xml --whitelist src/"
	}
}
